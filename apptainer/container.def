Bootstrap: docker
From: ubuntu:22.04

%help
	OMNI-EPIC: Open-endedness via Models of human Notions of Interestingness with Environments Programmed in Code

%files
	apptainer/10_nvidia.json /opt/nvidia/

%environment
	# System
	export TZ=Europe/London
	export OPENBLAS_NUM_THREADS=1

	# pyenv
	export PYENV_ROOT="/workdir/.pyenv"
	export PATH="$PYENV_ROOT/bin:$PATH"

	# Activate virtual environment permanently
	export VIRTUAL_ENV="/workdir/.venv"
	export _OLD_VIRTUAL_PATH="$PATH"
	export PATH="$VIRTUAL_ENV/bin:$PATH"

	# Add /workdir/ to PYTHONPATH
	export PYTHONPATH='/workdir'

	# EGL
	export __EGL_VENDOR_LIBRARY_DIRS='/opt/nvidia'

%post
	export DEBIAN_FRONTEND=noninteractive

	# Export environment variables permanently
	echo "export WANDB_API_KEY=$WANDB_API_KEY" >> $APPTAINER_ENVIRONMENT
	echo "export OPENAI_API_KEY=$OPENAI_API_KEY" >> $APPTAINER_ENVIRONMENT
	echo "export ANTHROPIC_API_KEY=$ANTHROPIC_API_KEY" >> $APPTAINER_ENVIRONMENT

	# Update and install required libraries
	apt update
	apt install -y unzip git curl wget ffmpeg build-essential libssl-dev zlib1g-dev libbz2-dev libreadline-dev libsqlite3-dev libncursesw5-dev xz-utils tk-dev libxml2-dev libxmlsec1-dev libffi-dev liblzma-dev libcairo2-dev libpango1.0-dev libsdl-pango-dev

	# Clone repository to /workdir/
	git clone https://github.com/maxencefaldor/omni-epic.git /workdir/

	# Install pyenv
	export PYENV_ROOT="/workdir/.pyenv"
	export PATH="$PYENV_ROOT/bin:$PATH"
	curl https://pyenv.run | bash
	eval "$(pyenv init -)"
	pyenv update
	rm -rf /workdir/.pyenv/.git/

	# Install Python
	pyenv install 3.11
	pyenv global 3.11

	# Create a virtual environment
	python -m venv /workdir/.venv
	. /workdir/.venv/bin/activate
	python -m ensurepip
	pip install --upgrade pip

	# Install repository
	cd /workdir/ && pip install -r requirements.txt

%runscript
	# Run main
	python /workdir/main.py "$@"
